                 RowBox[{"{", 
                  RowBox[{"\"\<Authorization\>\"", "->", 
                   RowBox[{"\"\<Bearer \>\"", "<>", "token"}]}], "}"}]}], 
                "]"}]}], "|>"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
