           RowBox[{"Break", "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"raw", "=", 
          RowBox[{"Select", "[", 
           RowBox[{"raw", ",", 
            RowBox[{
             RowBox[{"!", 
