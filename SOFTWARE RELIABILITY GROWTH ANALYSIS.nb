ClearAll["Global`*"];

token = "";
owner = "apache";
repo = "dubbo";

fetchDataBugs[] :=
 Module[{allIssues = {}, page = 1, res, raw, bugDates, counts, 
   cumulative}, Print["Fetching GitHub data..."];
  While[page <= 15, 
   res = URLRead@
     HTTPRequest[
      "https://api.github.com/repos/" <> owner <> "/" <> repo <> 
       "/issues?state=all&per_page=100&page=" <> ToString[page], <|
       "Headers" -> 
        If[token == "", {}, {"Authorization" -> "Bearer " <> token}]|>];
   If[res["StatusCode"] != 200, Break[]];
   raw = ImportByteArray[ByteArray[res["BodyBytes"]], "RawJSON"];
   If[Length[raw] == 0 || ! ListQ[raw], Break[]];
   raw = Select[raw, ! KeyExistsQ[#, "pull_request"] &];
   allIssues = Join[allIssues, raw[[All, "created_at"]]];
   page++;];
  bugDates = 
   DateValue[DateObject[#], {"Year", "Month"}] & /@ allIssues;
  counts = KeySort[Counts[bugDates]];
  cumulative = Accumulate[Values[counts]];
  N[Thread[{Range[Length[cumulative]], cumulative}]]]

data = fetchDataBugs[];

aStart = data[[-1, 2]];
len = Length[data];

goel = NonlinearModelFit[
   data, {a (1 - Exp[-b*t]), a > 0, 
    0 < b < 1}, {{a, aStart}, {b, 0.02}}, t];

delayedSshaped = 
  NonlinearModelFit[
   data, {a (1 - (1 + b*t) Exp[-b*t]), a > 0, 
    0 < b < 1}, {{a, aStart}, {b, 0.05}}, t];

inflectionSshaped = 
  NonlinearModelFit[
   data, {(a (1 - Exp[-b*t]))/(1 + \[Beta]*Exp[-b*t]), a > 0, 
    0 < b < 1, \[Beta] > 0}, {{a, aStart}, {b, 0.05}, {\[Beta], 1.1}},
    t, Method -> "NMinimize"];

musa = Quiet[
   NonlinearModelFit[
    data, {(1/th) Log[1 + l0 th t], l0 > 0, 
     th > 0}, {{l0, 10}, {th, 0.01}}, t, Method -> "NMinimize"]];

hdgo = Quiet[
   NonlinearModelFit[
    data, {a (1 - Exp[-b*t^c]), a > 0, b > 0, 
     c > 0}, {{a, aStart}, {b, 0.01}, {c, 1.1}}, t, 
    Method -> "NMinimize"]];

models = <|"Goel-Okumoto" -> goel, 
   "Yamada S-Shaped" -> delayedSshaped, 
   "Inflection S-Shaped" -> inflectionSshaped, "Musa-Okumoto" -> musa, 
   "HD/G-O" -> hdgo|>;

DynamicModule[{availableModels = {"Goel-Okumoto", "Yamada S-Shaped", 
    "Inflection S-Shaped", "Musa-Okumoto", "HD/G-O"}, 
  selected = {"Goel-Okumoto", "Yamada S-Shaped", "Inflection S-Shaped",
     "Musa-Okumoto", "HD/G-O"}, showData = True, 
  pastelPurple = RGBColor[0.85, 0.8, 0.95], 
  modelColors = <|"Goel-Okumoto" -> ColorData[97, 1], 
    "Yamada S-Shaped" -> ColorData[97, 2], 
    "Inflection S-Shaped" -> ColorData[97, 3], 
    "Musa-Okumoto" -> ColorData[97, 4], "HD/G-O" -> ColorData[97, 5]|>},
  Framed[Column[{Framed[
     Style["SOFTWARE RELIABILITY GROWTH ANALYSIS: APACHE DUBBO", 22, 
      Bold, Darker[Gray, 0.7]], Background -> pastelPurple, 
     FrameStyle -> GrayLevel[0.5], RoundingRadius -> 8, 
     ImageSize -> {Automatic, 40}, FrameMargins -> {{40, 40}, {10, 10}},
      Alignment -> Center], Spacer[15], 
    Grid[{{Framed[
        Column[{Item[Style["CONTROLS", 18, Bold, White], 
           Alignment -> Center], 
          Graphics[{White, Thickness[0.01], Line[{{-1, 0}, {1, 0}}]}, 
           ImageSize -> {180, 5}], Spacer[15], 
          Framed[Style["Select Models:", 12, Bold, Black], 
           Background -> pastelPurple, FrameStyle -> None, 
           RoundingRadius -> 4, ImageSize -> 185], Spacer[10], 
          Column[Table[
            With[{k = k}, 
             Toggler[Dynamic[MemberQ[selected, k], 
               If[#, selected = DeleteDuplicates[Append[selected, k]],
                  selected = DeleteCases[selected, k]] &], {True -> 
                Row[{Graphics[{pastelPurple, Rectangle[{0, 0}, {1, 1}],
                     White, Thickness[0.15], 
                    Line[{{0.2, 0.5}, {0.4, 0.2}, {0.8, 0.8}}]}, 
                   ImageSize -> 14], Spacer[8], 
                  Style[k, 11, White, Bold]}], 
               False -> 
                Row[{Graphics[{GrayLevel[0.3], EdgeForm[GrayLevel[0.6]],
                     Rectangle[{0, 0}, {1, 1}]}, ImageSize -> 14], 
                  Spacer[8], Style[k, 11, White, Bold]}]}]], {k, 
             availableModels}], Spacings -> 1.2], Spacer[30], 
          Framed[Style["Visual Settings:", 12, Bold, Black], 
           Background -> pastelPurple, FrameStyle -> None, 
           RoundingRadius -> 4, ImageSize -> 185], Spacer[10], 
          Toggler[Dynamic[
            showData], {True -> 
             Row[{Graphics[{pastelPurple, Rectangle[{0, 0}, {1, 1}], 
                 White, Thickness[0.15], 
                 Line[{{0.2, 0.5}, {0.4, 0.2}, {0.8, 0.8}}]}, 
                ImageSize -> 14], Spacer[8], 
               Style["Show Raw Data", 11, White, Bold]}], 
            False -> 
             Row[{Graphics[{GrayLevel[0.3], EdgeForm[GrayLevel[0.6]], 
                 Rectangle[{0, 0}, {1, 1}]}, ImageSize -> 14], 
               Spacer[8], Style["Show Raw Data", 11, White, Bold]}]}],
           Spacer[120]}, Alignment -> Left], RoundingRadius -> 10, 
        Background -> GrayLevel[0.2], FrameStyle -> GrayLevel[0.6], 
        ImageSize -> {220, 500}], Spacer[10],
       
       Framed[
        Row[{Dynamic[
           Plot[Evaluate[Table[models[k][t], {k, selected}]], {t, 1, 
             len}, PlotStyle -> 
             Table[Directive[modelColors[k], Thickness[0.007]], {k, 
               selected}], PlotTheme -> "Scientific", 
            ImageSize -> {440, 420}, AspectRatio -> 0.7, 
            GridLines -> Automatic, GridLinesStyle -> GrayLevel[0.4], 
            Epilog -> 
             If[showData, {Red, PointSize[0.015], Point[data]}, {}], 
            FrameLabel -> {Style["Time (Months)", White, 12], 
              Style["Cumulative Bugs", White, 12]}, 
            FrameStyle -> White, Background -> GrayLevel[0.2], 
            ImagePadding -> {{85, 10}, {50, 10}}]], Spacer[15], 
          Dynamic[Grid[
            Table[{Graphics[{modelColors[k], EdgeForm[None], 
                Rectangle[{0, 0}, {1, 1}]}, ImageSize -> 14], 
              Style[k, 11, White, Bold]}, {k, selected}], 
            Alignment -> Left, Spacings -> {1, 1.5}]]}, 
         Alignment -> Center], RoundingRadius -> 10, 
        Background -> GrayLevel[0.2], FrameStyle -> GrayLevel[0.5], 
        ImageSize -> {Automatic, 500}, FrameMargins -> 15], Spacer[10],
       
       Framed[
        Column[{Item[Style["METRICS", 16, Bold, pastelPurple], 
           Alignment -> Center], Spacer[10], 
          Dynamic[Grid[
            Join[{{Style["Model", Bold, pastelPurple], 
               Style["AIC", Bold, pastelPurple], 
               Style["AICc", Bold, pastelPurple], 
               Style["BIC", Bold, pastelPurple], 
               Style["RSquared", Bold, pastelPurple], 
               Style["Adj. RSquared", Bold, pastelPurple]}}, 
             Table[{Style[k, 10, White], 
               Style[NumberForm[Quiet[models[k]["AIC"]], {6, 2}], 11, 
                "Courier", White], 
               Style[NumberForm[Quiet[models[k]["AICc"]], {6, 2}], 11,
                 "Courier", White], 
               Style[NumberForm[Quiet[models[k]["BIC"]], {6, 2}], 11, 
                "Courier", White], 
               Style[NumberForm[Quiet[models[k]["RSquared"]], {4, 6}],
                 11, "Courier", White], 
               Style[NumberForm[
                 Quiet[models[k]["AdjustedRSquared"]], {4, 6}], 11, 
                "Courier", White]}, {k, selected}]], 
            Alignment -> Center, Frame -> All, 
            FrameStyle -> GrayLevel[0.4], Spacings -> {1.5, 2.0}, 
            Background -> {None, {None, {GrayLevel[0.15], 
                GrayLevel[0.22]}}}, ItemSize -> {{11, 6, 6, 6, 8, 8}}]]},
          Alignment -> Center], RoundingRadius -> 10, 
        Background -> GrayLevel[0.2], FrameStyle -> GrayLevel[0.6], 
        ImageSize -> {Automatic, 500}, FrameMargins -> 20]}}, 
     Spacings -> {0, 0}, Alignment -> Center]}, Alignment -> Center], 
  RoundingRadius -> 15, Background -> GrayLevel[0.85], 
  FrameStyle -> GrayLevel[0.4], FrameMargins -> 20, 
  ImageSize -> Automatic]]
